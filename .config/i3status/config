# i3status configuration file.
# see "man i3status" for documentation.
# icon sources: 
# https://www.nerdfonts.com/cheat-sheet
# https://fontawesome.com/search

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ├Я
# If the above line is not correctly displayed, fix your editor first!

# general {
#         colors = true
#         interval = 5
#         color_good = "#2AA198"
#         color_bad = "#586E75"
#         color_degraded = "#DC322F"
# }

general {
        colors = true
        interval = 5
        color_good = "#a6e3a1"
        color_bad = "#f38ba8"
        color_degraded = "#f38ba8"
}

# order += "ipv6"
order += "volume master"
order += "cpu_usage"
order += "memory"
order += "disk /"
order += "disk /home"
order += "disk /mnt/d"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
# order += "load"
# order += "tztime berlin"
# order += "tztime utc"
order += "tztime local"


volume master {
  format = "яАи   %volume"
  format_muted = "яАж  muted"
  device = "pulse"
}

cpu_usage {
        format = "яТ╝   %usage"

}

load {
        format = " load %1min "
        # max_threshold = 0.3
}

disk "/" {
        # format = " hdd %avail "
        format = "тЫБ %avail"
        # format = "ЁЯЦ┤ %avail"
}

disk "/home" {
        # format = " hdd %avail "
        format = "юмЖ  %avail"
        # format = "ЁЯПа %avail"
}

disk "/mnt/d" {
        format = "ЁЯЦ┤ %avail"
}

wireless _first_ {
# if you use %speed, i3status requires root privileges
        format_up = "яЗл   %ip"
        format_down = "яЗл   down"
}

ethernet _first_ {
# if you use %speed, i3status requires root privileges
        # format_up = " lan: %ip %speed "
        format_up = "яЫ┐ %ip"
        format_down = ""
}

battery all {
        format = "%status %percentage"
        format_down = "No battery"
        last_full_capacity = true
        integer_battery_capacity = true
        # status_chr = "тЪб"
        status_chr ="яЗж "
        status_bat = "яЙБ  "
        status_unk = "? "
        status_full = "яЙА  "
        low_threshold = 15
        threshold_type = time
        #format = "%status %percentage %remaining %emptytime"
        # status_chr = "яЗж"
        # status_bat = "bat"
        # status_bat = "тШЙ"
        # status_bat = "яИУ "
        #status_unk = ""
        # status_full = "тШ╗ "
}

memory {
        format = "юЙж   %used"
        threshold_degraded = "1G"
        format_degraded = "юЙж   %used"
        # format_degraded = "MEMORY < %available"
}

tztime local {
        #format = "%d/%m/%Y %H:%M:%S"
        format = "яБ│  %a %d %b %Y  яАЧ %H:%M"
        # format = "ЁЯУЕ %a %d %b %Y  ЁЯХЩ %H:%M"
}

tztime berlin {
        format = "berlin: %H:%M"
        timezone = "Europe/Berlin"
}

tztime utc {
        format = "яГ│ %H:%M"
        # format = "тП▓я╕П %H:%M"
        timezone = "UTC"
}
