#!/usr/bin/env bash

## Trick yazi into using chafa backend

# Hide graphical session information
unset WAYLAND_DISPLAY
# unset DISPLAY
export XDG_SESSION_TYPE=dumb

yy() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd" || exit
  fi
  rm -vi --preserve-root -f -- "$tmp"
}

yy "$@"
