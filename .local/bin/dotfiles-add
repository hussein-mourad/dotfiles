#!/bin/bash

DOTFILES_DIR="$HOME/dotfiles"
INPUT_PATH="$1"

# Function to print usage
usage() {
  cat <<EOF
Usage: $0 <path-to-file-or-directory>

Copy a file/directory to the corresponding path inside ~/dotfiles and run 'make' to link it.

Examples:
  $0 ~/.config/nvim        -> $DOTFILES_DIR/.config/nvim
  $0 ~/.bashrc             -> $DOTFILES_DIR/.bashrc
  $0 /etc/hosts            -> $DOTFILES_DIR/etc/hosts
  $0 ~/.local/bin/script   -> $DOTFILES_DIR/.local/bin/script

EOF
  exit 1
}

# Check if input path is provided
if [ -z "$INPUT_PATH" ]; then
  echo "Error: No path provided"
  usage
fi

# Expand ~ to home directory and resolve the path
INPUT_PATH="${INPUT_PATH/#\~/$HOME}"
INPUT_PATH=$(realpath "$INPUT_PATH" 2>/dev/null || echo "$INPUT_PATH")
INPUT_PATH="${INPUT_PATH%/}"

# Check if input exists
if [ ! -e "$INPUT_PATH" ]; then
  echo "Error: '$INPUT_PATH' does not exist"
  exit 1
fi

# Check if dotfiles directory exists
if [ ! -d "$DOTFILES_DIR" ]; then
  echo "Error: Dotfiles directory '$DOTFILES_DIR' does not exist"
  exit 1
fi

# Get the relative path from home directory
# If the path starts with /home/username/, remove it
if [[ "$INPUT_PATH" == "$HOME"* ]]; then
  # Remove the home directory prefix and the leading slash
  RELATIVE_PATH="${INPUT_PATH#$HOME/}"
else
  # For system paths like /etc, remove the leading slash
  RELATIVE_PATH="${INPUT_PATH#/}"
fi

DEST_PATH="$DOTFILES_DIR/$RELATIVE_PATH"

echo "Input path: $INPUT_PATH"
echo "Destination: $DEST_PATH"

# Create the destination directory if it doesn't exist
DEST_DIR=$(dirname "$DEST_PATH")
if [ ! -d "$DEST_DIR" ]; then
  echo "Creating destination directory: $DEST_DIR"
  mkdir -p "$DEST_DIR"
fi

# Check if destination already exists
if [ -e "$DEST_PATH" ]; then
  echo "Warning: Destination '$DEST_PATH' already exists"
  read -p "Do you want to overwrite? (y/n): " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Operation cancelled"
    exit 0
  fi
  # Remove existing file/directory
  rm -rf "$DEST_PATH"
fi

# Copy the file/directory to dotfiles
echo "Copying '$INPUT_PATH' to '$DEST_PATH'"
cp -ir "$INPUT_PATH" "$DEST_PATH"

# Check if copy was successful
if [ $? -ne 0 ]; then
  echo "Error: Failed to copy '$INPUT_PATH' to '$DEST_PATH'"
  exit 1
fi

echo "✅ Successfully copied to dotfiles"

# Change to dotfiles directory and run make
echo "Changing to dotfiles directory: $DOTFILES_DIR"
cd "$DOTFILES_DIR" || {
  echo "Error: Failed to change to '$DOTFILES_DIR'"
  exit 1
}

# Check if Makefile exists
if [ ! -f "Makefile" ]; then
  echo "Warning: No Makefile found in '$DOTFILES_DIR'"
  echo "Skipping 'make' command"
  exit 0
fi

# Run make
echo "Running 'make' to link the configuration..."
make

# Check if make was successful
if [ $? -eq 0 ]; then
  echo "✅ Successfully linked configuration"
else
  echo "❌ Error: 'make' command failed"
  exit 1
fi
